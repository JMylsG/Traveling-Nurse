# Copy this file to .dev.vars (gitignored) for local testing.
# For production, set each as a secret:  npx wrangler secret put <NAME>
# The forms stay dormant (soft "opening soon" notice) until these exist.

# Resend Audience ID -> powers /api/subscribe (the email list). Create an
# Audience in the Resend dashboard (Audiences tab) and paste its ID here.
# Uses RESEND_API_KEY below. The chosen specialty is emailed to CONTACT_TO
# since Resend audiences store email only.
RESEND_AUDIENCE_ID=""

# Resend API key -> powers /api/contact (partner form + feedback widget).
RESEND_API_KEY=""

# Where partner inquiries and feedback are delivered (Drew's email).
CONTACT_TO=""

# Optional verified sender, e.g. "TNG Website <site@drewsdomain.com>".
# Defaults to Resend's onboarding sender, fine for testing.
CONTACT_FROM=""

# OPTIONAL rate-limit raisers for the market page's data feeds. The page works
# without them, but shared CI IPs can hit the keyless caps on busy days.
# Free BLS v2 key (instant): https://data.bls.gov/registrationEngine/
BLS_API_KEY=""
# Free api.data.gov key (instant email signup): https://api.data.gov/signup/
# Without it the GSA feed uses DEMO_KEY (30 req/hr; some cities may skip stipends).
GSA_API_KEY=""

# Cloudflare Turnstile secret key -> server-side bot check on all 3 forms.
# The public site key is hardcoded in components/Turnstile.jsx. Without this
# secret the forms still work (the check is skipped); set it to enforce. Copy it
# from the Turnstile widget you create in the Cloudflare dashboard.
TURNSTILE_SECRET_KEY=""
